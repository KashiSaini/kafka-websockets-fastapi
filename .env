PROJECT_NAME=live-crypto-stream
APP_ENV=development

POSTGRES_USER=postgres
POSTGRES_PASSWORD=kashi
POSTGRES_DB=market_data
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:kashi@postgres:5432/market_data

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CLIENT_ID=market-app
KAFKA_TOPIC_TRADES=market.binance.trades
KAFKA_TOPIC_KLINES=market.binance.klines
KAFKA_CONSUMER_GROUP=market-consumer-group

BINANCE_WS_BASE=wss://data-stream.binance.vision/stream?streams=
TRACKED_SYMBOLS=btcusdt,ethusdt,bnbusdt
CANDLE_INTERVAL=1m
WS_PUSH_INTERVAL_SECONDS=1
